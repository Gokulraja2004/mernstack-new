pipeline {
    agent any

    environment {
        QA_SERVER   = "15.206.184.2"
        PROD_SERVER = "52.66.225.201"

        SERVER_USER = "ubuntu"
    }

    stages {

        stage('Clone Repository') {
            steps {

                git branch: 'main',
                url: 'https://github.com/Gokulraja2004/mernstack-new.git'
            }
        }

        stage('Build Frontend') {
            steps {

                dir('MERN-E-Commerce-Store-main/frontend') {

                    sh 'npm install --legacy-peer-deps'

                    sh 'npm run build'
                }
            }
        }

        stage('Deploy to QA') {
            steps {

                sh """
                ssh -o StrictHostKeyChecking=no ${SERVER_USER}@${QA_SERVER} '
                    rm -rf /home/ubuntu/qa-app
                    mkdir -p /home/ubuntu/qa-app
                '
                """

                sh """
                rsync -avz --exclude=node_modules --exclude=.git \
                -e "ssh -o StrictHostKeyChecking=no" \
                MERN-E-Commerce-Store-main/ \
                ${SERVER_USER}@${QA_SERVER}:/home/ubuntu/qa-app
                """

                sh """
                ssh -o StrictHostKeyChecking=no ${SERVER_USER}@${QA_SERVER} '

                    # BACKEND
                    cd /home/ubuntu/qa-app/backend

                    npm install --legacy-peer-deps

                    pm2 delete qa-app || true

                    PORT=5001 pm2 start index.js --name qa-app

                    # FRONTEND
                    cd /home/ubuntu/qa-app/frontend

                    npm install --legacy-peer-deps

                    npm run build

                    pm2 delete frontend || true

                    pm2 start "npx serve -s dist -l 3000" --name frontend

                    pm2 save
                '
                """
            }
        }

        stage('Approval for Production') {
            steps {
                input message: 'Deploy to Production?'
            }
        }

        stage('Deploy to PROD') {
            steps {

                sh """
                ssh -o StrictHostKeyChecking=no ${SERVER_USER}@${PROD_SERVER} '
                    rm -rf /home/ubuntu/prod-app
                    mkdir -p /home/ubuntu/prod-app
                '
                """

                sh """
                rsync -avz --exclude=node_modules --exclude=.git \
                -e "ssh -o StrictHostKeyChecking=no" \
                MERN-E-Commerce-Store-main/ \
                ${SERVER_USER}@${PROD_SERVER}:/home/ubuntu/prod-app
                """

                sh """
                ssh -o StrictHostKeyChecking=no ${SERVER_USER}@${PROD_SERVER} '

                    # BACKEND
                    cd /home/ubuntu/prod-app/backend

                    npm install --legacy-peer-deps

                    pm2 delete prod-app || true

                    PORT=5002 pm2 start index.js --name prod-app

                    # FRONTEND
                    cd /home/ubuntu/prod-app/frontend

                    npm install --legacy-peer-deps

                    npm run build

                    pm2 delete prod-frontend || true

                    pm2 start "npx serve -s dist -l 3001" --name prod-frontend

                    pm2 save
                '
                """
            }
        }
    }

    post {

        success {
            echo 'Pipeline Success ✅'
        }

        failure {
            echo 'Pipeline Failed ❌'
        }
    }
}